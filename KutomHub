local function make(cls, props, parent)
    local obj = Instance.new(cls)
    for k, v in pairs(props) do obj[k] = v end
    if parent then obj.Parent = parent end return obj
end
local function addCorner(p, r) return make("UICorner", {CornerRadius = UDim.new(0, r)}, p) end
local function addStroke(p, c, t) return make("UIStroke", {Color=c, Thickness=t, ApplyStrokeMode=Enum.ApplyStrokeMode.Border}, p) end
local function tween(obj, t, props) if obj and TS then TS:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), props):Play() end end

