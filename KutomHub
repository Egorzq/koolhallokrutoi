        hideWindow(mainFrame, mainStroke) task.wait(0.4) sgui:Destroy()
    end)
end)

local speed = 5 
RunService.Heartbeat:Connect(function()
    local hue = tick() % speed / speed
    local rgbColor = Color3.fromHSV(hue, 0.8, 1)
    mainStroke.Color = rgbColor openStroke.Color = rgbColor title.TextColor3 = rgbColor
end)

showWindow(mainFrame, mainStroke, UDim2.new(0, 280, 0, 480))

local isHidden = false
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        isHidden = not isHidden
        if isHidden then
            hideWindow(mainFrame, mainStroke) hideWindow(openBtn, openStroke)
        else
            if isMinimized then showWindow(openBtn, openStroke, UDim2.new(0, 50, 0, 50))
            else showWindow(mainFrame, mainStroke, UDim2.new(0, 280, 0, 480)) end
        end
    end
end)
