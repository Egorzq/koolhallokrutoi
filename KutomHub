        local k = inp.KeyCode.Name binds[bindId] = (k~="Escape" and k~="Backspace") and k or nil
        if bindBtnObj then
            bindBtnObj.Text = binds[bindId] and ("["..binds[bindId].."]") or "[ - ]"
            bindBtnObj.TextColor3 = binds[bindId] and C3(150,255,150) or C3(150,150,150)
        end
        isBind = false 
        if string.sub(bindId, 1, 3) == "TP_" then
            local tName = string.sub(bindId, 4)
            if teleports[tName] then teleports[tName].bind = binds[bindId] saveData() end
        end
        return
    end

    if gp then return end
    if inp.UserInputType == Enum.UserInputType.Keyboard then
        local k = inp.KeyCode.Name
        
        -- ОТКРЫТИЕ/ЗАКРЫТИЕ ПО КАСТОМНОЙ КНОПКЕ ИЛИ CTRL
        if k == mySetts.toggleKey or k == "LeftControl" or k == "RightControl" then
            isHidden = not isHidden
            if isHidden then hideWin(mainFrame, mainStroke) hideWin(openBtn, openStroke) else if minBtn.Visible and openBtn.Size.X.Offset>10 then showWin(openBtn, openStroke, U2(0,50,0,50)) else showWin(mainFrame, mainStroke, getWinSize()) end end
            return
        end

        for id, bk in pairs(binds) do
            if bk == k then
                if id == "VIP_Fly" then
                    if vipScr.Visible then toggleFly() end
                elseif string.sub(id, 1, 3) == "TP_" then
                    if vipScr.Visible then
                        local tName = string.sub(id, 4)
                        if teleports[tName] then
                            local d = teleports[tName].pos
                            tpToPos(CFrame.new(d[1], d[2], d[3], d[4], d[5], d[6], d[7], d[8], d[9], d[10], d[11], d[12]))
                        end
                    end
                else 
                    local a = currentAnimTrack if a and a.IsPlaying and string.find(a.Animation.AnimationId, id) then a:Stop() currentAnimTrack=nil else playAnim(id) end 
                end
                break
            end
        end
    end
end)
