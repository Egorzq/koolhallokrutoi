local function setMovementAnim(stateName, animName, newId)
    if not newId or newId == "" then return end
    local char = player.Character if not char then return end
    local animateScript = char:FindFirstChild("Animate")
    if animateScript then
        local stateObj = animateScript:FindFirstChild(stateName)
        if stateObj then
            local animObj = stateObj:FindFirstChild(animName)
            if animObj and animObj:IsA("Animation") then
                if not string.match(newId, "^rbxassetid://") then newId = "rbxassetid://" .. newId end
                animObj.AnimationId = newId
            end
        end
    end
end

local function applyMovementSet(idle, walk, run, jump, fall)
    idleInput.Text = idle or "" walkInput.Text = walk or "" runInput.Text = run or "" jumpInput.Text = jump or "" fallInput.Text = fall or ""
    setMovementAnim("idle", "Animation1", idle) setMovementAnim("idle", "Animation2", idle) setMovementAnim("walk", "WalkAnim", walk) setMovementAnim("run", "RunAnim", run) setMovementAnim("jump", "JumpAnim", jump) setMovementAnim("fall", "FallAnim", fall)
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then local animator = hum:FindFirstChildOfClass("Animator") if animator then for _, track in ipairs(animator:GetPlayingAnimationTracks()) do track:Stop() end end end
    end
end

