    local stroke = Instance.new("UIStroke") stroke.Color = Color3.fromRGB(80, 80, 100) stroke.Thickness = 1 stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border stroke.Parent = btn
    
