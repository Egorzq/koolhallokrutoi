local isFly, fConn, bv, bg = false, nil, nil, nil
crCh("Полет", nil, 6, function(_, btn)
    isFly = not isFly local c = player.Character if not c then return end local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
    if isFly then
        btn.Text="Выкл Полет" btn.BackgroundColor3=C3(200,50,50)
        bv=make("BodyVelocity",{MaxForce=Vector3.new(9e9,9e9,9e9)},hrp) bg=make("BodyGyro",{MaxTorque=Vector3.new(9e9,9e9,9e9), P=10000},hrp)
        local cam = workspace.CurrentCamera
        fConn = RS.RenderStepped:Connect(function()
            if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then isFly=false fConn:Disconnect() return end
            bg.CFrame = cam.CFrame local mv = Vector3.new()
            if UIS:IsKeyDown(Enum.KeyCode.W) then mv=mv+cam.CFrame.LookVector end if UIS:IsKeyDown(Enum.KeyCode.S) then mv=mv-cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then mv=mv-cam.CFrame.RightVector end if UIS:IsKeyDown(Enum.KeyCode.D) then mv=mv+cam.CFrame.RightVector end
            bv.Velocity = mv.Magnitude>0 and mv.Unit*flySpeed or Vector3.zero
        end)
    else btn.Text="Полет" btn.BackgroundColor3=C3(40,120,200) if fConn then fConn:Disconnect() end if bv then bv:Destroy() end if bg then bg:Destroy() end end
end)

