local function playAnim(animId)
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
    if currentAnimTrack then currentAnimTrack:Stop() end
    local idToPlay = animId
    if not string.match(idToPlay, "^rbxassetid://") then idToPlay = "rbxassetid://" .. idToPlay end
    local animation = Instance.new("Animation") animation.AnimationId = idToPlay
    currentAnimTrack = animator:LoadAnimation(animation)
    currentAnimTrack:Play()
end

local function createButton(name, id, isSpecial, order)
    local btn = Instance.new("TextButton") btn.Size = UDim2.new(1, -10, 0, 38) btn.LayoutOrder = order or 1 
    local defaultColor = isSpecial and Color3.fromRGB(40, 160, 60) or Color3.fromRGB(40, 40, 50)
    local hoverColor = isSpecial and Color3.fromRGB(60, 200, 80) or Color3.fromRGB(60, 60, 80)
    btn.BackgroundColor3 = defaultColor btn.TextColor3 = Color3.fromRGB(230, 230, 230) btn.Text = name btn.Font = Enum.Font.GothamSemibold btn.TextSize = 14 btn.AutoButtonColor = false btn.Parent = emotesScroll
