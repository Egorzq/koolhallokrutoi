local function playAnim(id)
    local char = player.Character if not char then return end local hum = char:FindFirstChildOfClass("Humanoid") if not hum then return end
    local anim = hum:FindFirstChildOfClass("Animator") or make("Animator", {}, hum)
    if currentAnimTrack then currentAnimTrack:Stop() end
    local a = make("Animation", {AnimationId = string.match(id, "^rbxassetid://") and id or "rbxassetid://"..id})
    currentAnimTrack = anim:LoadAnimation(a) currentAnimTrack.Looped = isLoop currentAnimTrack:Play()
end

local function setupBind(btn, id)
    local k = binds[id] btn.Text = k and ("["..k.."]") or "[ - ]" btn.TextColor3 = k and C3(150,255,150) or C3(150,150,150)
    btn.MouseButton1Click:Connect(function() if isBind then return end isBind, bindId, bindBtnObj = true, id, btn btn.Text="[...]" btn.TextColor3=C3(255,200,50) end)
end

local function makeEmote(name, id, isCust)
    local c = make("Frame", {Size=U2(1,-10,0,38), BackgroundTransparency=1, LayoutOrder=isCust and 3 or 2}, scrEmotes)
    local w = isCust and U2(1,-88,1,0) or U2(1,-44,1,0)
    local pb = make("TextButton", {Size=w, BackgroundColor3=C3(40,40,50), TextColor3=C3(230,230,230), Text=(isCust and "⭐ " or "▶ ")..name, Font=Enum.Font.GothamSemibold, TextSize=14}, c)
    addCorner(pb,8) addStroke(pb,C3(80,80,100),1)
    local px = isCust and U2(1,-82,0,0) or U2(1,-38,0,0)
    local bb = make("TextButton", {Size=U2(0,38,1,0), Position=px, BackgroundColor3=C3(30,30,40), Font=Enum.Font.GothamBold, TextSize=12}, c)
    addCorner(bb,8) addStroke(bb,C3(80,80,100),1) setupBind(bb, id)
    pb.MouseButton1Down:Connect(function() tween(pb,0.1,{Size=w-U2(0,4,0,4)}) end)
    pb.MouseButton1Up:Connect(function() tween(pb,0.1,{Size=w}) playAnim(id) end)
    if isCust then
        local db = make("TextButton", {Size=U2(0,38,1,0), Position=U2(1,-38,0,0), BackgroundColor3=C3(60,30,35), TextColor3=C3(255,100,100), Text="🗑️", Font=Enum.Font.GothamBold, TextSize=14}, c)
        addCorner(db,8) addStroke(db,C3(120,50,50),1)
        db.MouseButton1Click:Connect(function() ask("Удалить эмоцию?", function() for i,v in ipairs(customAnims) do if v.id==id then table.remove(customAnims,i) break end end binds[id]=nil saveData() c:Destroy() end) end)
    end
end

