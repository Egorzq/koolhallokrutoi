local saveFileName = "MyCustomAnims.json"
local customAnims = {}
local binds = {} 

local function loadData()
    if isfile and isfile(saveFileName) then
        local success, result = pcall(function() return HttpService:JSONDecode(readfile(saveFileName)) end)
        if success and type(result) == "table" then 
            if result.customAnims then
                customAnims = result.customAnims
                binds = result.binds or {}
            else
                customAnims = result
                binds = {}
            end
        end
    end
end

local function saveData()
    if writefile then
        local dataToSave = { customAnims = customAnims, binds = binds }
        local success, result = pcall(function() return HttpService:JSONEncode(dataToSave) end)
        if success then writefile(saveFileName, result) end
    end
end

