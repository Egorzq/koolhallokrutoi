local function createCheat(name, placeholder, order, callback)
    local container = Instance.new("Frame") container.Size = UDim2.new(1, 0, 0, 45) container.BackgroundTransparency = 1 container.LayoutOrder = order container.Parent = secretContent
    local input, btnSize, btnPos = nil, UDim2.new(1, 0, 1, 0), UDim2.new(0, 0, 0, 0)
    if placeholder then
        input = Instance.new("TextBox") input.Size = UDim2.new(0.6, -10, 1, 0) input.BackgroundColor3 = Color3.fromRGB(15, 15, 20) input.TextColor3 = Color3.fromRGB(255, 255, 255) input.PlaceholderText = placeholder input.Font = Enum.Font.Gotham input.TextSize = 14 input.Parent = container
        local c = Instance.new("UICorner") c.CornerRadius = UDim.new(0,8) c.Parent = input
        local s = Instance.new("UIStroke") s.Color = Color3.fromRGB(80,80,100) s.Thickness=1 s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border s.Parent = input
        btnSize, btnPos = UDim2.new(0.4, 0, 1, 0), UDim2.new(0.6, 0, 0, 0)
    end
    local btn = Instance.new("TextButton") btn.Size = btnSize btn.Position = btnPos btn.BackgroundColor3 = Color3.fromRGB(40, 120, 200) btn.TextColor3 = Color3.fromRGB(255, 255, 255) btn.Text = name btn.Font = Enum.Font.GothamBold btn.TextSize = 14 btn.Parent = container
    local c2 = Instance.new("UICorner") c2.CornerRadius = UDim.new(0,8) c2.Parent = btn
    btn.MouseButton1Click:Connect(function() local val = input and input.Text or nil callback(val, btn) end)
    return container
end

