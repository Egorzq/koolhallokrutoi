-- Функция для создания полей ввода
local function createInput(placeholder, yPos)
    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0.8, 0, 0, 30)
    input.Position = UDim2.new(0.1, 0, 0, yPos)
    input.PlaceholderText = placeholder
    input.Text = ""
    input.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    input.TextColor3 = Color3.new(1, 1, 1)
    input.Parent = mainFrame
    return input
end

local inputPos1 = createInput("Точка А (X, Y, Z)", 60)
local inputPos2 = createInput("Точка B (X, Y, Z)", 100)

-- Кнопки "Взять текущие координаты"
local function createGetBtn(text, yPos, targetInput)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.8, 0, 0, 25)
    btn.Position = UDim2.new(0.1, 0, 0, yPos)
    btn.Text = text
    btn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Parent = mainFrame
    
    btn.MouseButton1Click:Connect(function()
        local pos = rootPart.Position
        targetInput.Text = string.format("%.1f, %.1f, %.1f", pos.X, pos.Y, pos.Z)
    end)
    return btn
end

createGetBtn("Записать точку А", 140, inputPos1)
