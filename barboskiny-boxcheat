-- === ФУНКЦИИ ===

local function parseCoords(str)
	local coords = {}
	for val in string.gmatch(str, "([^,]+)") do table.insert(coords, tonumber(val)) end
	return #coords == 3 and Vector3.new(coords[1], coords[2], coords[3]) or nil
end

local function createPointRow()
	local frame = Instance.new("Frame", scrollFrame)
	frame.Size = UDim2.new(1, -10, 0, 35)
	frame.BackgroundTransparency = 1
	
	local input = Instance.new("TextBox", frame)
	input.Size = UDim2.new(0.55, 0, 1, 0)
	input.PlaceholderText = "X, Y, Z"
	input.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	input.TextColor3 = Color3.new(1, 1, 1)
	input.TextScaled = true
	
	local getBtn = Instance.new("TextButton", frame)
	getBtn.Size = UDim2.new(0.25, 0, 1, 0)
	getBtn.Position = UDim2.new(0.57, 0, 0, 0)
	getBtn.Text = "Тут"
	getBtn.BackgroundColor3 = Color3.fromRGB(0, 85, 127)
	getBtn.TextColor3 = Color3.new(1, 1, 1)
	
	local delBtn = Instance.new("TextButton", frame)
	delBtn.Size = UDim2.new(0.15, 0, 1, 0)
	delBtn.Position = UDim2.new(0.84, 0, 0, 0)
	delBtn.Text = "X"
	delBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
	delBtn.TextColor3 = Color3.new(1, 1, 1)

	local entry = {Frame = frame, Input = input}
	table.insert(pointsList, entry)

	getBtn.MouseButton1Click:Connect(function()
		input.Text = string.format("%.1f, %.1f, %.1f", rootPart.Position.X, rootPart.Position.Y, rootPart.Position.Z)
	end)

	delBtn.MouseButton1Click:Connect(function()
		for i, v in ipairs(pointsList) do if v == entry then table.remove(pointsList, i) break end end
		frame:Destroy()
	end)
end

