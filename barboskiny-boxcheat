local function stopMoving()
	isMoving = false
	rootPart.Anchored = false -- Важно: размораживаем при остановке
	startBtn.Text = "НАЧАТЬ ПРЫЖКИ"; startBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 70)
end

startBtn.MouseButton1Click:Connect(function()
	if isMoving then stopMoving() return end
	
	local validPoints = {}
	for _, entry in ipairs(pointsList) do
		local pos = parseCoords(entry.Input.Text)
		if pos then table.insert(validPoints, pos) end
	end
	
	if #validPoints < 1 then return end

	isMoving = true
	startBtn.Text = "СТОП"
	startBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
	local waitTime = tonumber(speedInput.Text) or 1

	task.spawn(function()
		while isMoving do
			for _, targetPos in ipairs(validPoints) do
				if not isMoving then break end
				
				-- 1. МГНОВЕННЫЙ ТЕЛЕПОРТ
				rootPart.Anchored = false -- Размораживаем на миллисекунду для ТП
				rootPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
				
				-- 2. МГНОВЕННАЯ ЗАМОРОЗКА
				task.wait(0.05) -- Крошечная пауза чтобы движок Roblox обновил позицию
				rootPart.Anchored = true
				
				-- 3. РАБОТА С PROMPT
				if autoDetectPrompts then
					local prompt = findNearestPrompt()
					if prompt then
						rootPart.CFrame = CFrame.lookAt(rootPart.Position, prompt.Parent:GetPivot().Position)
						startBtn.Text = "ЖМУ: " .. (prompt.ObjectText or "???")
local key = prompt.KeyboardKeyCode
						VirtualInputManager:SendKeyEvent(true, key, false, game)
						task.wait(prompt.HoldDuration + 0.2)
						VirtualInputManager:SendKeyEvent(false, key, false, game)
						
						task.wait(0.3)
						startBtn.Text = "СТОП"
					end
				end
				
				-- Ждем перед следующим прыжком
				task.wait(waitTime)
			end
			
			if not isLooping then stopMoving(); break end
		end
	end)
end)

