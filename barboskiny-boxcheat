local function stopMoving()
	isMoving = false
	if currentTween then currentTween:Cancel() end
	startBtn.Text = "ЗАПУСТИТЬ"
	startBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 70)
end

-- Основной цикл движения
startBtn.MouseButton1Click:Connect(function()
	if isMoving then stopMoving() return end
	
	local validPoints = {}
	for _, entry in ipairs(pointsList) do
		local pos = parseCoords(entry.Input.Text)
		if pos then table.insert(validPoints, pos) end
	end
	
	if #validPoints < 1 then return end

	isMoving = true
	startBtn.Text = "СТОП"
  startBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
	
	local duration = tonumber(speedInput.Text) or 2
	local holdDuration = tonumber(holdInput.Text) or 2

	task.spawn(function()
		while isMoving do
			for i, targetPos in ipairs(validPoints) do
				if not isMoving then break end
				
				-- 1. Движение к точке
				if i == 1 and not currentTween then
					rootPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
				else
					local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
					currentTween = TweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))})
					currentTween:Play()
					currentTween.Completed:Wait()
				end
				
				-- 2. Взаимодействие (Нажатие E)
				if useInteraction and isMoving then
					startBtn.Text = "НАЖИМАЮ E..."
					-- Симуляция зажатия
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
					
					task.wait(holdDuration)
					
					-- Симуляция отпускания
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
					startBtn.Text = "СТОП"
				end
				
				task.wait(0.2)
			end
			
			if not isLooping then stopMoving(); break end
		end
	end)
end)

RunService.RenderStepped:Connect(function()
