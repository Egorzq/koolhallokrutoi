local function stopMoving()
	isMoving = false; if currentTween then currentTween:Cancel() end
	startBtn.Text = "ЗАПУСТИТЬ ТЕСТ"; startBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 70)
end

startBtn.MouseButton1Click:Connect(function()
	if isMoving then stopMoving() return end
	local validPoints = {}
	for _, entry in ipairs(pointsList) do
		local pos = parseCoords(entry.Input.Text)
		if pos then table.insert(validPoints, pos) end
	end
	if #validPoints < 1 then return end

	isMoving = true; startBtn.Text = "СТОП"; startBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
	local speed = tonumber(speedInput.Text) or 2

	task.spawn(function()
		while isMoving do
			for _, targetPos in ipairs(validPoints) do
				if not isMoving then break end
				
				-- Полет к точке
				local tweenInfo = TweenInfo.new(speed, Enum.EasingStyle.Linear)
				currentTween = TweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))})
				currentTween:Play()
				currentTween.Completed:Wait()
				
				-- УМНОЕ НАЖАТИЕ
				if autoDetectPrompts and isMoving then
					local prompt = findNearestPrompt()
					if prompt then
-- 1. Доворачиваем персонажа к промпту (чтобы он точно был в фокусе)
						rootPart.CFrame = CFrame.lookAt(rootPart.Position, prompt.Parent:GetPivot().Position)
						
						startBtn.Text = "АКТИВАЦИЯ: " .. prompt.ObjectText
						task.wait(0.2)
						
						-- 2. Симулируем нажатие клавиши промпта (обычно E)
						local key = prompt.KeyboardKeyCode
						VirtualInputManager:SendKeyEvent(true, key, false, game)
						
						-- 3. Ждем ровно столько, сколько требует промпт + 0.1 сек запаса
						task.wait(prompt.HoldDuration + 0.1)
						
						VirtualInputManager:SendKeyEvent(false, key, false, game)
						task.wait(0.5) -- Пауза после активации
						startBtn.Text = "СТОП"
					end
				end
			end
			if not isLooping then stopMoving(); break end
		end
	end)
end)
