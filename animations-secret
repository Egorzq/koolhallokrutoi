local function showWindow(frame, stroke, targetSize)
    frame.Visible = true
    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = targetSize}):Play()
    if stroke then TweenService:Create(stroke, TweenInfo.new(0.4), {Transparency = 0}):Play() end
end

local function hideWindow(frame, stroke)
    TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)}):Play()
    if stroke then TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 1}):Play() end
    task.delay(0.35, function()
        if frame.Size.X.Offset < 5 then frame.Visible = false end
    end)
end

