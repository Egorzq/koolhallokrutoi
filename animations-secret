-- ==========================================
-- СКРЫТИЕ/ПОКАЗ МЕНЮ НА 'CONTROL'
-- ==========================================
local isHidden = false
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.RightControl then
        isHidden = not isHidden
        if isHidden then
            -- Плавное скрытие
            TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)}):Play()
        else
            -- Плавное появление
            TweenService:Create(mainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 280, 0, 400)}):Play()
        end
    end
end)
