local player = game:GetService("Players").LocalPlayer
local currentAnimTrack = nil

-- Создаем базовый интерфейс (ScreenGui)
local gui = Instance.new("ScreenGui")
gui.Name = "SimpleAnimPlayer"
gui.ResetOnSpawn = false
gui.Parent = game:GetService("CoreGui") or player.PlayerGui

-- Создаем главное окно
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 250, 0, 150)
frame.Position = UDim2.new(0.5, -125, 0.5, -75)
frame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true -- Менюшку можно перетаскивать мышкой!
frame.Parent = gui

-- Заголовок
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Text = "Плеер Анимаций"
title.Font = Enum.Font.SourceSansBold
title.TextSize = 18
title.BorderSizePixel = 0
title.Parent = frame

-- Поле для ввода ID
local textBox = Instance.new("TextBox")
textBox.Size = UDim2.new(0.9, 0, 0, 30)
textBox.Position = UDim2.new(0.05, 0, 0, 40)
textBox.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
textBox.PlaceholderText = "Введи ID анимации..."
textBox.Text = ""
textBox.Font = Enum.Font.SourceSans
textBox.TextSize = 16
textBox.ClearTextOnFocus = false
textBox.Parent = frame

-- Кнопка Play
local playBtn = Instance.new("TextButton")
playBtn.Size = UDim2.new(0.4, 0, 0, 30)
playBtn.Position = UDim2.new(0.05, 0, 0, 80)
playBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
playBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
playBtn.Text = "▶ Play"
playBtn.Font = Enum.Font.SourceSansBold
playBtn.TextSize = 16
playBtn.Parent = frame

-- Кнопка Stop
local stopBtn = Instance.new("TextButton")
stopBtn.Size = UDim2.new(0.4, 0, 0, 30)
stopBtn.Position = UDim2.new(0.55, 0, 0, 80)
stopBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
stopBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
stopBtn.Text = "⏹ Stop"
stopBtn.Font = Enum.Font.SourceSansBold
stopBtn.TextSize = 16
stopBtn.Parent = frame

-- Кнопка закрытия меню
local closeBtn = Instance.new("TextButton")
closeBtn.Size = UDim2.new(0, 30, 0, 30)
closeBtn.Position = UDim2.new(1, -30, 0, 0)
closeBtn.BackgroundTransparency = 1
closeBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
closeBtn.Text = "X"
closeBtn.Font = Enum.Font.SourceSansBold
closeBtn.TextSize = 18
closeBtn.Parent = frame

-- Логика кнопки Play
playBtn.MouseButton1Click:Connect(function()
    local animId = textBox.Text
    if animId == "" then return end

    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = humanoid
    end

    if currentAnimTrack then
        currentAnimTrack:Stop()
    end

    local idToPlay = animId
    if not string.match(idToPlay, "^rbxassetid://") then
        idToPlay = "rbxassetid://" .. idToPlay
    end

    local animation = Instance.new("Animation")
    animation.AnimationId = idToPlay

    currentAnimTrack = animator:LoadAnimation(animation)
    currentAnimTrack:Play()
end)

-- Логика кнопки Stop
stopBtn.MouseButton1Click:Connect(function()
    if currentAnimTrack then
        currentAnimTrack:Stop()
    end
end)

-- Логика закрытия
closeBtn.MouseButton1Click:Connect(function()
    gui:Destroy()
end)
