local function hideConfirmation()
    TweenService:Create(confirmBox, TweenInfo.new(0.2, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)}):Play()
    local hideTween = TweenService:Create(confirmOverlay, TweenInfo.new(0.2), {BackgroundTransparency = 1})
    hideTween:Play()
    hideTween.Completed:Connect(function() confirmOverlay.Visible = false end)
end

