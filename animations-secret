local saveFileName = "MyCustomAnims.json"
local customAnims = {}

local function loadCustomAnims()
    if isfile and isfile(saveFileName) then
        local success, result = pcall(function() return HttpService:JSONDecode(readfile(saveFileName)) end)
        if success and type(result) == "table" then customAnims = result end
    end
end

local function saveCustomAnims()
    if writefile then
        local success, result = pcall(function() return HttpService:JSONEncode(customAnims) end)
        if success then writefile(saveFileName, result) end
    end
end

