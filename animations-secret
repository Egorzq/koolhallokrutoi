-- Загружаем библиотеку Orion
local OrionLib = loadstring(game:HttpGet(('https://raw.githubusercontent.com/shlexsoftware/Orion/main/source')))()

-- Создаем главное окно
local Window = OrionLib:MakeWindow({
    Name = "Animation Player",
    HidePremium = false, 
    SaveConfig = false, 
    IntroText = "Загрузка плеера..." 
})

-- Создаем вкладку для анимаций
local AnimTab = Window:MakeTab({
    Name = "Плеер",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

local player = game:GetService("Players").LocalPlayer
local currentAnimTrack = nil
local animationId = ""

-- Поле для ввода ID
AnimTab:AddTextbox({
    Name = "Введи ID Анимации",
    Default = "",
    TextDisappear = false,
    Callback = function(Value)
        animationId = Value
    end	  
})

-- Кнопка "Проиграть"
AnimTab:AddButton({
    Name = "▶ Проиграть",
    Callback = function()
        if animationId == "" then
            OrionLib:MakeNotification({Name = "Ошибка", Content = "Сначала введи ID!", Time = 3})
            return
        end

        local character = player.Character
        if not character then return end
        
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end
        
        -- Используем Animator для корректного воспроизведения
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if not animator then
            animator = Instance.new("Animator")
            animator.Parent = humanoid
        end

        -- Останавливаем предыдущую анимацию, если она играла
        if currentAnimTrack then
            currentAnimTrack:Stop()
        end

        -- Форматируем ID для движка Roblox
        local idToPlay = animationId
        if not string.match(idToPlay, "^rbxassetid://") then
            idToPlay = "rbxassetid://" .. idToPlay
        end

        local animation = Instance.new("Animation")
        animation.AnimationId = idToPlay

        -- Загружаем и запускаем
        currentAnimTrack = animator:LoadAnimation(animation)
        currentAnimTrack:Play()
        
        OrionLib:MakeNotification({Name = "Успех", Content = "Анимация запущена!", Time = 2})
    end    
})

-- Кнопка "Остановить"
AnimTab:AddButton({
    Name = "⏹ Остановить",
    Callback = function()
        if currentAnimTrack then
            currentAnimTrack:Stop()
            OrionLib:MakeNotification({Name = "Остановлено", Content = "Анимация прервана.", Time = 2})
        end
    end    
})

-- Инициализируем GUI
OrionLib:Init()
