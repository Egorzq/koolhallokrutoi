local function playAnim(animId)
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)
    if currentAnimTrack then currentAnimTrack:Stop() end
    local idToPlay = animId
    if not string.match(idToPlay, "^rbxassetid://") then idToPlay = "rbxassetid://" .. idToPlay end
    local animation = Instance.new("Animation")
    animation.AnimationId = idToPlay
    currentAnimTrack = animator:LoadAnimation(animation)
    currentAnimTrack:Play()
end

-- Создание обычной кнопки
local function createButton(name, id, isSpecial, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 38)
    btn.LayoutOrder = order or 1 
    
    local defaultColor = isSpecial and Color3.fromRGB(40, 160, 60) or Color3.fromRGB(40, 40, 50)
    local hoverColor = isSpecial and Color3.fromRGB(60, 200, 80) or Color3.fromRGB(60, 60, 80)
    
    btn.BackgroundColor3 = defaultColor
    btn.TextColor3 = Color3.fromRGB(230, 230, 230)
    btn.Text = name
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 14
    btn.AutoButtonColor = false
    btn.Parent = scroll
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(80, 80, 100)
    stroke.Thickness = 1
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = btn

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = hoverColor}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(255, 255, 255)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = defaultColor}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(80, 80, 100)}):Play()
    end)
    btn.MouseButton1Down:Connect(function() TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1, -14, 0, 34)}):Play() end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1, -10, 0, 38)}):Play()
        if id then playAnim(id) end
    end)
    return btn
end

-- Создание КАСТОМНОЙ кнопки (с кнопкой удаления)
local function createCustomButton(name, id)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, -10, 0, 38)
    container.BackgroundTransparency = 1
    container.LayoutOrder = 2
    container.Parent = scroll

    -- Кнопка запуска анимации (занимает 85% ширины)
    local playBtn = Instance.new("TextButton")
    playBtn.Size = UDim2.new(1, -44, 1, 0)
    playBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    playBtn.TextColor3 = Color3.fromRGB(230, 230, 230)
    playBtn.Text = "⭐ " .. name
    playBtn.Font = Enum.Font.GothamSemibold
    playBtn.TextSize = 14
    playBtn.AutoButtonColor = false
    playBtn.Parent = container
    local corner1 = Instance.new("UICorner") corner1.CornerRadius = UDim.new(0, 8) corner1.Parent = playBtn
    local stroke1 = Instance.new("UIStroke") stroke1.Color = Color3.fromRGB(80, 80, 100) stroke1.Thickness = 1 stroke1.ApplyStrokeMode = Enum.ApplyStrokeMode.Border stroke1.Parent = playBtn

    -- Кнопка удаления (🗑️)
    local delBtn = Instance.new("TextButton")
    delBtn.Size = UDim2.new(0, 38, 1, 0)
    delBtn.Position = UDim2.new(1, -38, 0, 0)
    delBtn.BackgroundColor3 = Color3.fromRGB(60, 30, 35)
    delBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    delBtn.Text = "🗑️"
    delBtn.Font = Enum.Font.GothamBold
    delBtn.TextSize = 14
    delBtn.AutoButtonColor = false
    delBtn.Parent = container
    local corner2 = Instance.new("UICorner") corner2.CornerRadius = UDim.new(0, 8) corner2.Parent = delBtn
    local stroke2 = Instance.new("UIStroke") stroke2.Color = Color3.fromRGB(120, 50, 50) stroke2.Thickness = 1 stroke2.ApplyStrokeMode = Enum.ApplyStrokeMode.Border stroke2.Parent = delBtn

    -- Анимации наведения для Play
    playBtn.MouseEnter:Connect(function() TweenService:Create(playBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 60, 80)}):Play() end)
    playBtn.MouseLeave:Connect(function() TweenService:Create(playBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 50)}):Play() end)
    playBtn.MouseButton1Down:Connect(function() TweenService:Create(playBtn, TweenInfo.new(0.1), {Size = UDim2.new(1, -48, 0, 34)}):Play() end)
    playBtn.MouseButton1Up:Connect(function() 
        TweenService:Create(playBtn, TweenInfo.new(0.1), {Size = UDim2.new(1, -44, 1, 0)}):Play()
        playAnim(id)
    end)

    -- Анимации наведения для Delete
    delBtn.MouseEnter:Connect(function() TweenService:Create(delBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(200, 50, 50), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play() end)
    delBtn.MouseLeave:Connect(function() TweenService:Create(delBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 30, 35), TextColor3 = Color3.fromRGB(255, 100, 100)}):Play() end)
    
    -- ЗАПРОС ПОДТВЕРЖДЕНИЯ ПРИ УДАЛЕНИИ
    delBtn.MouseButton1Click:Connect(function()
        showConfirmation("Удалить анимацию\n'" .. name .. "'?", function()
            -- Ищем и удаляем из таблицы сохранения
            for i, v in ipairs(customAnims) do
                if v.name == name and v.id == id then
                    table.remove(customAnims, i)
                    break
                end
            end
            saveCustomAnims()
            container:Destroy() -- Удаляем саму кнопку из меню
        end)
    end)
end

