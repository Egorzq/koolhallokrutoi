-- ==========================================
-- ЛОГИКА АНИМАЦИЙ
-- ==========================================
local function playAnim(animId)
    local character = player.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local animator = humanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", humanoid)

    if currentAnimTrack then currentAnimTrack:Stop() end

    local idToPlay = animId
    if not string.match(idToPlay, "^rbxassetid://") then
        idToPlay = "rbxassetid://" .. idToPlay
    end

    local animation = Instance.new("Animation")
    animation.AnimationId = idToPlay

    currentAnimTrack = animator:LoadAnimation(animation)
    currentAnimTrack:Play()
end

-- ==========================================
-- ФУНКЦИЯ СОЗДАНИЯ КРАСИВЫХ КНОПОК
-- ==========================================
local function createButton(name, id, isSpecial)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 38)
    
    -- Разные цвета для обычных и специальных кнопок
    local defaultColor = isSpecial and Color3.fromRGB(40, 160, 60) or Color3.fromRGB(40, 40, 50)
    local hoverColor = isSpecial and Color3.fromRGB(60, 200, 80) or Color3.fromRGB(60, 60, 80)
    
    btn.BackgroundColor3 = defaultColor
    btn.TextColor3 = Color3.fromRGB(230, 230, 230)
    btn.Text = name
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 14
    btn.AutoButtonColor = false -- Отключаем стандартный клик Роблокса
    btn.Parent = scroll
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = btn
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(80, 80, 100)
    stroke.Thickness = 1
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = btn

    -- Плавные анимации при наведении мыши
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = hoverColor}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(150, 150, 255)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = defaultColor}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(80, 80, 100)}):Play()
    end)
    
    -- Анимация клика
    btn.MouseButton1Down:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1, -14, 0, 34)}):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {Size = UDim2.new(1, -10, 0, 38)}):Play()
        if id then playAnim(id) end
    end)
    
    return btn
end

