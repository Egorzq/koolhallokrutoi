idInput.PlaceholderText = "Введите Asset ID..."; idInput.Text = ""
idInput.BackgroundColor3 = Color3.fromRGB(50, 50, 50); idInput.TextColor3 = Color3.new(1, 1, 1)
Instance.new("UICorner", idInput)

-- Список надетых вещей
local scrollFrame = Instance.new("ScrollingFrame", mainFrame)
scrollFrame.Size = UDim2.new(0.9, 0, 0, 220); scrollFrame.Position = UDim2.new(0.05, 0, 0, 200)
scrollFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45); scrollFrame.ScrollBarThickness = 4
local layout = Instance.new("UIListLayout", scrollFrame); layout.Padding = UDim.new(0, 5)

-- Функция добавления в список GUI
local function addItemToList(name, obj)
	local itemFrame = Instance.new("Frame", scrollFrame)
	itemFrame.Size = UDim2.new(1, -10, 0, 30); itemFrame.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
	Instance.new("UICorner", itemFrame)
	
	local itemText = Instance.new("TextLabel", itemFrame)
	itemText.Size = UDim2.new(0.7, 0, 1, 0); itemText.Position = UDim2.new(0.05, 0, 0, 0)
	itemText.Text = name; itemText.TextColor3 = Color3.new(1, 1, 1); itemText.BackgroundTransparency = 1; itemText.TextXAlignment = Enum.TextXAlignment.Left
	
	local delBtn = Instance.new("TextButton", itemFrame)
	delBtn.Size = UDim2.new(0.2, 0, 0.8, 0); delBtn.Position = UDim2.new(0.75, 0, 0.1, 0)
	delBtn.Text = "X"; delBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50); delBtn.TextColor3 = Color3.new(1, 1, 1)
	Instance.new("UICorner", delBtn)
	
	delBtn.MouseButton1Click:Connect(function()
		obj:Destroy()
		itemFrame:Destroy()
	end)
end

-- ЛОКАЛЬНАЯ ЛОГИКА НАДЕВАНИЯ
local function applyLocal(category)
	local id = tonumber(idInput.Text)
	if not id then return end
	
	local char = player.Character
	if not char then return end

	if category == "Shirt" then
		local s = char:FindFirstChildOfClass("Shirt") or Instance.new("Shirt", char)
		s.ShirtTemplate = "http://www.roblox.com/asset/?id=" .. id
		addItemToList("Shirt: "..id, s)
	elseif category == "Pants" then
local p = char:FindFirstChildOfClass("Pants") or Instance.new("Pants", char)
		p.PantsTemplate = "http://www.roblox.com/asset/?id=" .. id
		addItemToList("Pants: "..id, p)
	elseif category == "Accessory" then
		-- Важно: Локальные скрипты не могут использовать InsertService для большинства вещей из-за безопасности.
		-- Мы будем использовать специальный объект Accessory и меш.
		local acc = Instance.new("Accessory")
		local handle = Instance.new("Part", acc); handle.Name = "Handle"
		local mesh = Instance.new("SpecialMesh", handle)
		mesh.MeshId = "rbxassetid://" .. id
		-- Это упрощенный метод, настоящие аксессуары требуют сложной структуры. 
		-- Для полноценных аксессуаров лучше использовать серверный метод.
		acc.Parent = char
		addItemToList("Acc: "..id, acc)
	end
end

